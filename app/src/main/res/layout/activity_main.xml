<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F1A">

    <!-- 顶部标题（固定） -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="智能翻译"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#E8D5FF"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="中文 · English · Français"
        android:textSize="13sp"
        android:textColor="#8877AA"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <!-- 输入框：可自由滚动，高度自适应最小160dp -->
    <EditText
        android:id="@+id/input_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="160dp"
        android:hint="在此输入或粘贴要翻译的内容..."
        android:textColor="#E8D5FF"
        android:textSize="15sp"
        android:padding="16dp"
        android:gravity="top"
        android:background="@drawable/input_bg"
        android:inputType="textMultiLine"
        android:scrollbars="vertical"
        android:overScrollMode="always"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="12dp"/>

    <!-- 按钮区（固定在底部） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/clipboard_btn"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="📋 读取剪贴板"
                android:textSize="13sp"
                android:textColor="#0F0F1A"
                android:textStyle="bold"
                android:background="@drawable/btn_bg"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/input_btn"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="✏️ 翻译输入内容"
                android:textSize="13sp"
                android:textColor="#E8D5FF"
                android:textStyle="bold"
                android:background="@drawable/btn_bg2"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/clear_btn"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="🗑️ 清空"
            android:textSize="13sp"
            android:textColor="#AA8899"
            android:background="@drawable/btn_bg_clear"/>

    </LinearLayout>

    <!-- 翻译结果（可滚动） -->
    <ScrollView
        android:id="@+id/results_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/results_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="点击任意结果可直接复制"
                android:textSize="12sp"
                android:textColor="#665577"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="中文"
                android:textSize="13sp"
                android:textColor="#C084FC"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/zh_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F0E8FF"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5"
                android:padding="16dp"
                android:background="@drawable/result_bg"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="English"
                android:textSize="13sp"
                android:textColor="#60A5FA"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/en_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E8F0FF"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5"
                android:padding="16dp"
                android:background="@drawable/result_bg_blue"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Français"
                android:textSize="13sp"
                android:textColor="#34D399"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/fr_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E8FFF4"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5"
                android:padding="16dp"
                android:background="@drawable/result_bg_green"
                android:layout_marginBottom="30dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
